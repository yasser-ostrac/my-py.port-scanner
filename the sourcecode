import socket
import threading
import time

def scan_port(host, port):
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(0.5)
        result = s.connect_ex((host, port))
        if result == 0:
            risky_ports = {
                21: "FTP (unencrypted)",
                23: "Telnet (insecure)",
                25: "SMTP (can be abused)",
                445: "SMB (file sharing vulnerabilities)"
            }
            if port in risky_ports:
                print(f"⚠️ Port {port} OPEN — {risky_ports[port]}")
            else:
                print(f"✅ Port {port} is OPEN on {host}")
        else:
            print(f"❌ Port {port} is CLOSED on {host}")
        s.close()
    except Exception as e:
        print(f"Error scanning port {port}: {e}")

def run_scan(host):
    print(f"\n Starting new scan on {host}...\n")
    threads = []
    for port in range(1, 1025):
        t = threading.Thread(target=scan_port, args=(host, port))
        threads.append(t)
        t.start()
    for t in threads:
        t.join()
    print("✅ Scan complete.")

# Host to scan
host = "127.0.0.1"

# Loop: run scan every 12 seconds
while True:
    run_scan(host)
    print(" Waiting 12 seconds before next scan...\n")
    time.sleep(12)
